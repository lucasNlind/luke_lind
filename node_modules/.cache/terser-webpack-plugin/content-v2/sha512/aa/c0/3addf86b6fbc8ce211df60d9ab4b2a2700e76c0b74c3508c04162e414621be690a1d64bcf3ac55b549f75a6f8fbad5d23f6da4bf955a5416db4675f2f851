Link to='/projects/spotify'>\r\n            <img className=\"projectPostThumbnail\" src={spotifyThumbnail} alc=\"spotify-thumbnail\"></img>\r\n        </NavLink>\r\n    </div>\r\n    <div className=\"projectPostRight\">\r\n      <p className=\"projectPostHeader\">Spotify Weather Playlist Generator</p>\r\n      <p className=\"projectPostSubHeader\">2021</p>\r\n    </div>\r\n  </div>\r\n)\r\n\r\nexport default ProjectPostSpotify","export default __webpack_public_path__ + \"static/media/STRETCHED_THUMBNAIL.43f74097.png\";","import React from 'react'\r\nimport { NavLink } from 'react-router-dom'\r\n\r\nimport stretchedThumbnail from '../../../../assets/STRETCHED_THUMBNAIL.png'\r\n\r\nimport './ProjectPostStretched.css'\r\n\r\nconst ProjectPostStretched = () => (\r\n  <div className=\"projectPost\">\r\n    <div className=\"projectPostLeft\">\r\n        <NavLink to='/projects/stretched'>\r\n            <img className=\"projectPostThumbnail\" src={stretchedThumbnail} alc=\"spotify-thumbnail\"></img>\r\n        </NavLink>\r\n    </div>\r\n    <div className=\"projectPostRight\">\r\n      <p className=\"projectPostHeader\">Stretched: My Ecommerce Platform</p>\r\n      <p className=\"projectPostSubHeader\">2021</p>\r\n    </div>\r\n  </div>\r\n)\r\n\r\nexport default ProjectPostStretched","import React, { useEffect } from 'react'\r\n\r\nimport swedishFlag from '../../assets/FLAG-ICON.png';\r\nimport profileImage from '../../assets/profile-image.jpeg'\r\n\r\nimport ProjectPostSpotify from './Posts/ProjectPostSpotify/ProjectPostSpotify';\r\nimport ProjectPostStretched from './Posts/ProjectPostStretched/ProjectPostStretched';\r\n\r\nimport './FrontPage.css'\r\nimport 'aos/dist/aos.css'\r\nimport Aos from 'aos';\r\n\r\nconst FrontPage = () => {\r\n\r\n  useEffect(() => {\r\n    Aos.init( {duration: 1500} )\r\n  }, [])\r\n\r\n  return (\r\n    <div className=\"master\">\r\n      <link rel=\"stylesheet\" href=\"https://use.typekit.net/tru2emh.css\"></link>\r\n      <link rel=\"stylesheet\" href=\"bower_components/aos/dist/aos.css\" />\r\n      <div className=\"hero\">\r\n        <div className=\"heroLeft\">\r\n          <img className=\"heroImage\" src={profileImage} alt=\"profile-image\"></img>\r\n        </div>\r\n        <div className=\"heroRight\">\r\n          <p className=\"centralHeader\">\r\n            Hej, I'm Luke.\r\n          </p>\r\n          <div className=\"subHeader\">\r\n            <p className=\"subHeaderText\">\r\n              That's Swedish for hi. I'm half viking \r\n            </p>\r\n            <p className=\"subHeaderFlagWrapper\">\r\n              <img className=\"subHeaderFlag\"src={swedishFlag} alt=\"logo\"></img>\r\n          </p>\r\n        </div>\r\n      </div>\r\n      </div>\r\n      <div data-aos='fade-up' className=\"projectsWrapper\">\r\n            <p className=\"projectsHeader\">I code.</p>\r\n            <p className=\"projectsHeader\">I design.</p>\r\n            <p className=\"projectsHeader\">And I love music.</p>\r\n            <p className=\"projectsHeader\">(here are a couple things i'm proud of)</p>\r\n\t    <div className=\"myPostsWrapper\">\r\n               <ProjectPostSpotify></ProjectPostSpotify>\r\n               <ProjectPostStretched></ProjectPostStretched>\r\n            </div>\r\n      </div>\r\n    </div>\r\n  )\r\n}\r\n\r\nexport default FrontPage\r\n","export default __webpack_public_path__ + \"static/media/hero-test.0056e173.png\";","import React, { useEffect } from \"react\"\r\n\r\nimport heroTest from '../../assets/hero-test.png'\r\n\r\nimport './MusicPage.css'\r\nimport 'aos/dist/aos.css'\r\nimport Aos from 'aos';\r\n\r\nconst MusicPage = () => {\r\n\r\n    useEffect(() => {\r\n        Aos.init( {duration: 2000} )\r\n        window.scrollTo(0, 0)\r\n    }, [])\r\n\r\n    return (\r\n        <div data-aos='fade-zoom-in' data-aos-delay='700'>\r\n            <div className=\"musicPageHeroWrapper\">\r\n                <img className=\"musicPageHeroImage\" src={heroTest}></img>\r\n            </div>\r\n            <div className='subHeroWrapper'>\r\n                <p className=\"subHeroHeader\">\r\n                    Artistry: Bigger than music\r\n                </p>\r\n            </div>\r\n            <div className=\"postContent\">\r\n                <p>\r\n                    The deeper I get into music the more I fall in love with everything that comes with it...\r\n                    I only started releasing my work about a year ago but the more I do the more I realize\r\n                    how deep the concept of artistry goes.\r\n                </p>\r\n                <p>\r\n                    It's an expression of self.\r\n                </p>\r\n                <p>\r\n\t\t    I started tinkering with synth plugins in a software called FL Studio about four years ago. It was here\r\n\t\t    that I learned the basics of sound design and arrangement through simple trial and error. After this, I\r\n\t\t    graduated to more advanced techniques like equalization, compression, and audio effects like reverbs and delays. \r\n                </p>\r\n\t\t<p>\r\n\t\t    Using what I knew, I began making remixes of some of my favorite songs and posting beats to Soundcloud. I got a much better\r\n\t\t    response than I expected, so I kept refining my techniques with the hope of eventually producing my own material. A little over\r\n\t\t    two years ago, I posted my first original song to SoundCloud and the response was overwhelming. \r\n\t\t</p>\r\n\t\t<p>\r\n\t\t    Knowing that my music was enjoyable to others gave me the confidence to continue releasing original songs to SoundCloud. I was able to explore\r\n\t\t    different genres and refined techniques for live instrumentation and vocal recording. The more music I released, the more I fell in love with the \r\n\t\t    whole marketing and brand image side of music as well. Each song gave me the opportunity to create album art that not only fit the theme of the song\r\n\t\t    but also helped build a brand image for my page.  \r\n\t\t</p>\r\n\t\t<p>\r\n\t\t    More recently, I've been releasing my music to Spotify and Apple Music to reach a wider audience. I continue to explore different sounds and genres that are\r\n\t\t    meaningful to me, and I love continuing on my path of self-discovery through music. \r\n\t\t</p>\r\n                <p>\r\n                    I only wish this love to continue. Until then I don't plan on stopping keeping it alive. Check\r\n                    out my music on <a \r\n                    className=\"spotifyLink\"\r\n                    target='_blank' \r\n                    href='https://open.spotify.com/artist/59AlhR4PtpjQT0m5TsDAvN?si=Tf8BShN1QOCSsQ-4Ux164A'>\r\n                        Spotify\r\n                    </a>.\r\n                </p>\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default MusicPage\r\n","export default __webpack_public_path__ + \"static/media/spotify-post-hero.1d9741bc.jpg\";","import React, { useEffect } from 'react'\r\n\r\nimport spotifyProjectHero from '../../assets/spotify-post-hero.jpg'\r\n\r\nimport './SpotifyProjectPage.css'\r\n\r\nconst SpotifyProjectPage = () => {\r\n    useEffect(() => {\r\n        window.scrollTo(0, 0)\r\n    }, [])\r\n\r\n    return (\r\n        <div data-aos='fade-zoom-in' data-aos-delay='700'>\r\n            <link rel=\"stylesheet\" href=\"https://use.typekit.net/tru2emh.css\"></link>\r\n            <div className=\"musicPageHeroWrapper\">\r\n                <img alt='spotifyHero' className=\"musicPageHeroImageSpotify\" src={spotifyProjectHero}></img>\r\n            </div>\r\n            <div className='subHeroWrapperSpotify'>\r\n                <p className=\"subHeroHeaderSpotify\">\r\n                    Atmosphere: how it makes us feel\r\n                </p>\r\n            </div>\r\n            <div className=\"postContentSpotify\">\r\n                <p>\r\n                    I love how well a certain song can bring you to another place. Music has a really close relationship\r\n                    with atmoshpere in this way, and so I really wanted to explore how I could measure its strength with this project.\r\n                </p>\r\n                <p>\r\n                    I had a basic understanding of the Spotify API and some Python background, but I really didn't\r\n                    know where to start. It was all pretty intimidating at first, but I ended up finding this fantastic\r\n                    Python library called <a \r\n                    target='_blank' \r\n                    className='spotifyLink'\r\n                     href='https://spotipy.readthedocs.io/en/2.19.0/#'>Spotipy</a> that streamlined the entire process for me.\r\n\t\t    I needed only a Client ID and a Client Secret from my Spotify developer dashboard, as well as a redirect URI to verify my credentials. \r\n                </p>\r\n                <p>\r\n                    I started by creating playlists of my own on the Spotify App. In the spirit of simplicity I made\r\n                    two:\r\n                </p>\r\n                <div className=\"sunnyPlaylistWrapper\">\r\n                    <div className=\"sunnyPlaylistWrapperLeft\">\r\n                        <iframe \r\n                        src=\"https://open.spotify.com/embed/playlist/6h5GNBGSdzPy0SE6NOMddo\" \r\n                        width=\"100%\" \r\n                        height=\"380\" \r\n                        frameBorder=\"0\" \r\n                        allowfullscreen=\"\" \r\n                        allow=\"autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture\"></iframe>\r\n                    </div>\r\n                    <div className=\"sunnyPlaylistWrapperRight\">\r\n                        <iframe \r\n                        src=\"https://open.spotify.com/embed/playlist/5BqayxS0OumOudUrK6Txek?theme=0\" \r\n                        width=\"100%\" \r\n                        height=\"380\" \r\n                        frameBorder=\"0\" \r\n                        allowfullscreen=\"\" \r\n                        allow=\"autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture\"></iframe>\r\n                    </div>\r\n                </div>\r\n                <p>\r\n                    Ultimately, I was trying to figure out how my standards for a certain playlist (in this case, weather) \r\n                    matched up with Spotify's standards. This meant pulling data from the API to see what was going on under the hood.\r\n                </p>\r\n                <h2>Setting Threshholds</h2>\r\n                <p>\r\n                    Spotify stores a lot about each song, but there are some key pieces of information that really stick\r\n                    out. Valence, energy, and danceability are all song attributes that Spotify measures from a level 0 to 1:\r\n                </p>\r\n                <ul>\r\n                    <li>Valence: How uplifting a song is</li>\r\n                    <li>Energy: How energetic a song feels</li>\r\n                    <li>Danceability: How danceable the song is</li>\r\n                </ul>\r\n                <p>\r\n                    There's a lot more going on than just these three variables of course, but I was really interested to \r\n                    see how these in particular came together to create some sort of song profile.\r\n                </p>\r\n                <p>\r\n                    My approach involved using thresholds - meaning that I was tracking to see how many songs in a playlist\r\n                    fell above or below a threshold of, let's say, 0.75 valence. \r\n                </p>\r\n                <p>\r\n                    In doing so I was mostly concerned with the percentage of songs falling below this threshold. Let me break down the \r\n                    example I used earlier:\r\n                </p>\r\n                <p>\r\n                    <span className='underline'>Higher</span> valence means a more positive song - and positive songs are ones I'd put in a 'Sunny Day' playlist.\r\n                </p>\r\n                <p>\r\n                    <span className='underline'>Lower</span> valence means a more somber song - and somber songs are ones I'd put in a 'Rainy Day' playlist.\r\n                </p>\r\n                <h3>Thus...</h3>\r\n                <ul>\r\n                    <li>\r\n                        I can expect a <span className='underline'>lower</span> percentage of songs to fall below 0.75 valence for a 'Sunny Day' playlist.\r\n                    </li>\r\n                    <li>\r\n                        I can also expect a <span className='underline'>higher</span> percentage of songs to fall below 0.75 valence for a 'Rainy Day' playlist.\r\n                    </li>\r\n                </ul>\r\n                <p>\r\n                    As straightforward as the approach was, I think it was effective in highlighting some of the factors that really\r\n                    help a song fit some kind of atmoshpere. Valence, energy, and danceability were the three best indicators. \r\n                </p>\r\n\t\t<p>\r\n\t\t    There were, of course, other indicators. I mentioned earlier that Spotify stores more than just these three variables - two of them being\r\n\t\t    song key and tempo. Going into the project, I was expecting these two attributes to be at least somewhat indicative of where a song\r\n\t\t    fit based on weather. However, I couldn't find any reasonable correlation while tracking these variables.\r\n\t\t</p>\r\n\t\t<p>\r\n\t\t    My assumption was that a more uptempo song would indicate a more positive one and therefore it would fit in a Sunny weather playlist. Likewise,\r\n\t\t    I assumed that a song in a major key would fit in a Sunny weather playlist because major keys are typically more positive and uplifting. If you know\r\n\t\t    anything about music theory or production, it is not nearly this simple.  \r\n\t\t</p>\r\n\t\t<p>\r\n\t\t    The thing with tempo is that it's very difficult to put any kind of threshold on it, especially as it relates to measuring some level of positivty. \r\n\t\t    The tempo of a song usually has to do with what genre it falls under. Dance music typically falls in the range of 112-124 BPM, RnB is typically anywhere\r\n\t\t    from 60-80 BPM, and Pop music falls anywhere from 100-130 BPM. The amount of overlap makes it difficult to target a song's atmosphere, and a song's tempo\r\n\t\t    acts as more of a general basis from where you can take a song emotionally. \r\n\t\t</p>\r\n\t\t<p>\r\n\t\t    Key is what suprised me the most. Basic music theory suggests that happier songs are typically written in major scales and vice versa with more somber ones.\r\n\t\t    The problem is, you can have a major scale that is the exact same sequence of notes as a minor scale. Take the scale of C major (all of the white notes on a\r\n\t\t    piano keyboard), for example. If you compare it with A minor, the sequence of notes is exactly the same. This overlap also made it difficult to use thresholds. \r\n\t\t</p>\r\n                <h2>\r\n                    The Recommendations\r\n                </h2>\r\n                <p>\r\n                    Understanding the metrics was important, but I needed some way of generating recommendations for each user. \r\nlucaslind@s172-20-22-h76 src % ls\r\nApp.css\t\t\tcomponents\t\treportWebVitals.js\r\n                    Luckily, Spotify's API provides a list of recommendations per user based on their short, medium, and long term listening\r\n                    history. I used this to generate a large list of recommended songs. \r\n                </p>\r\n                <p>\r\n                    Once I had this, I simply had to pull weather data from a separate API to determine the current weather at a specific\r\n                    location. If it were sunny, I'd take my list of recommendations and choose ones with higher levels of valence, danceability, and energy to give to the user.\r\n\t\t    If it were rainy or overcast, I'd do the opposite. \r\n                </p>\r\n                <h2>\r\n                    Conclusion\r\n                </h2>\r\n                <p>\r\n                    I think it's difficult to put statistics on something as subjective as music, but I do think that Spotify has done an\r\n                    incredible job at reflecting that subjectivity in their metrics. Ultimately, I had mixed feelings about the recommendations\r\n                    from my application and think that the filtering mechanism could've benefitted from some genre matching.\r\n                </p>\r\n\t\t<p>\r\n\t\t    I would have also liked to further explore song key and tempo. While it is difficult to use my method of setting thresholds for the both of these attributes,\r\n\t\t    there are other ways of finding correlations. I'd like to go a bit deeper into music theory and figure out what actually makes a key more positive or negative\r\n\t\t    , and I think I could replace my analysis of tempo by applying certain ranges to specific genres. \r\n\t\t</p>\r\n                <p>\r\n                    Overall, however, I'm really happy with the way that it turned out and I learned a bunch!\r\n                </p>\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default SpotifyProjectPage\r\n","export default __webpack_public_path__ + \"static/media/stretched_hero.e89b89ed.png\";","export default __webpack_public_path__ + \"static/media/stretched_demo_image_1.84d7d8dc.png\";","export default __webpack_public_path__ + \"static/media/stretched_demo_image_2.de72ffea.png\";","export default __webpack_public_path__ + \"static/media/stretched_demo_image_3.c47cc89c.png\";","import React, { useEffect } from 'react'\r\n\r\nimport stretchedHero from '../../assets/stretched_hero.png'\r\nimport stretchedDemoOne from '../../assets/stretched_demo_image_1.png'\r\nimport stretchedDemoTwo from '../../assets/stretched_demo_image_2.png'\r\nimport stretchedDemoThree from '../../assets/stretched_demo_image_3.png'\r\n\r\nimport './StretchedProjectPage.css'\r\n\r\nconst StretchedProjectPage = () => {\r\n    useEffect(() => {\r\n        window.scrollTo(0, 0)\r\n    }, [])\r\n\r\n    return (\r\n        <div data-aos='fade-zoom-in' data-aos-delay='700'>\r\n            <link rel=\"stylesheet\" href=\"https://use.typekit.net/tru2emh.css\"></link>\r\n            <div className=\"demoImagesWrapper\">\r\n                <div className='imageCol1'>\r\n                    <img alt='spotifyHero' className=\"stretchedDemoImage\" src={stretchedHero}></img>\r\n                    <img alt='spotifyHero' className=\"stretchedDemoImage\" src={stretchedDemoOne}></img>\r\n                </div>\r\n                <div className='imageCol2'>\r\n                    <div className='colTwoHeader'>\r\n                        <h2 className='headerClass'>Stretched</h2>\r\n                    </div>\r\n                    <img alt='spotifyHero' className=\"stretchedDemoImage\" src={stretchedDemoTwo}></img>\r\n                    <img alt='spotifyHero' className=\"stretchedDemoImage\" src={stretchedDemoThree}></img>\r\n                </div>\r\n            </div>\r\n            <div className='subHeroWrapperSpotify'>\r\n                <p className=\"subHeroHeaderSpotify\">\r\n                    The Journey\r\n                </p>\r\n            </div>\r\n            <div className=\"postContentSpotify\">\r\n                <p>\r\n                    I paired up with my current business partner about a year ago in helping her develop this \r\n                    idea of hers. Long story short, she recognized how crazy the demand was for high-end athleisure\r\n                    products - specifically used ones. \r\n                </p>\r\n                <p>\r\n                    There are, in fact, several Facebook marketplaces with over 40 thousand members each that\r\n                    exist solely for the purpose of buying and selling secondhand Lululemon products. She and I both knew\r\n                    that we could make our own marketplace that not only looked and felt better but also \r\n                    provided something unique to the user. And so, Stretched was born.\r\n                </p>\r\n                <h2>\r\n                    The Platform\r\n                </h2>\r\n                <p>\r\n\t\t    The platform itself has been entirely mine to build from the ground up. My partner (a mom of six\r\n\t\t    children with a full-time job) handles the financials and works with her connections to get our platform\r\n\t\t    the exposure it needs. I handle the technical and design stuff.\r\n\t\t</p>\r\n\t\t<p>\r\n\t\t    For our specific platform, we needed a peer-to-peer marketplace. This is different from a traditional marketplace\r\n\t\t    in that the platform allows anyone to become a seller once they sign up. We wanted to build a community of users\r\n\t\t    based on trust, so we needed the right platform to do so.\r\n\t\t</p>\r\n\t\t<p> \r\n\t\t    One of the first platforms I came across was an open-source marketplace software developed by a company called\r\n                    <a target='_blank' href='https://www.sharetribe.com/' className='spotifyLink'> ShareTribe</a>.\r\n                    I have nothing but good things to say about this company. \r\n                </p>\r\n                <p>\r\n                    Not only do they provide complete templates for peer-to-peer marketplaces, but their support system\r\n                    and developer network is so rich. After I did my (mostly aesthetic) work on the platform, Sharetribe\r\n                    connected me with a great team of developers that I hired to finish out the project. \r\n                </p>\r\n\t\t<p>\r\n\t\t    I spent a good month laying out a roadmap for the developers before they started their work. When they started,\r\n\t\t    I ensured that there were weekly meetings between us where we could go over updates, changes, and problems. It\r\n\t\t    was my first experience leading a project with a team of my own. \r\n\t\t</p>\r\n                <p>\r\n\t\t    In tandem, I've been working with my business partner in developing the platform from a business side of things.\r\n\t\t    We are constantly discussing tradeoffs for implementing new features and we both really believe in bringing this idea to life.\r\n\t\t    We are expected to launch sometime in December 2021!\r\n                </p>\r\n            </div>\r\n        </div>\r\n    )\r\n\r\n}\r\n\r\nexport default StretchedProjectPage\r\n","export default __webpack_public_path__ + \"static/media/AboutMeHero.b97dab78.JPG\";","import React from 'react'\r\n\r\nimport aboutMeHero from '../../assets/AboutMeHero.JPG'\r\n\r\nimport './AboutMePage.css'\r\n\r\nconst AboutMePage = () => {\r\n    return (\r\n        <div data-aos='fade-zoom-in' data-aos-delay='700'>\r\n            <div className=\"musicPageHeroWrapper\">\r\n                <img className=\"musicPageHeroImageAbout\" src={aboutMeHero}></img>\r\n            </div>\r\n            <div className='subHeroWrapperSpotify'>\r\n                <p className=\"subHeroHeaderAboutMe\">\r\n                    About Me\r\n                </p>\r\n            </div>\r\n            <div className=\"postContent\">\r\n                <p>\r\n                    Hey! I'm Luke. I'm a third year Finance turned Computer Science major at UGA, but I've been\r\n                    programming since my Sophomore year of high school. I've always been drawn to the amount of\r\n                    different opportunities available in tech, and love integrating my creative endeavors with\r\n                    Computer Science. \r\n                </p>\r\n                <p>\r\n                    I recently took on 